# Normalize line endings: treat everything as text and check out with LF.
* text=auto eol=lf

# Explicit text files
*.go      text eol=lf
*.sql     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.mod     text eol=lf
*.sum     text eol=lf
*.json    text eol=lf
*.env     text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf

# Windows scripts keep CRLF
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Binary files (never modify)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
